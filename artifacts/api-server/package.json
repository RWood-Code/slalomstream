{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx ./src/index.ts",
    "build": "tsx ./build.ts",
    "start": "node artifacts/api-server/dist/index.cjs",
    "serve": "SERVE_STATIC=true STATIC_DIR=./public node ./dist/index.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@workspace/api-zod": "workspace:*",
    "@workspace/db": "workspace:*",
    "cheerio": "^1.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "dropbox": "^10.34.0",
    "express": "^5",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.27.3",
    "tsx": "catalog:"
  }
}
